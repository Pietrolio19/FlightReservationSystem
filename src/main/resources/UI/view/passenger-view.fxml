<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="UI.controller.flight.PassengerController"
            prefHeight="400.0" prefWidth="600.0"
            fitToWidth="true">

    <content>
        <VBox fillWidth="true" maxWidth="Infinity">
            <Label text="Dati Passeggeri" styleClass="seat-reservation-title-text"/>
            <VBox fx:id="passengerCardsArea">

            </VBox>
            <HBox>
                <Button fx:id="backToSeatReservation" text="Indietro" styleClass="secondary-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="continueButton" text="Conferma" styleClass="primary-button"/>
            </HBox>
        </VBox>
    </content>

</ScrollPane>
