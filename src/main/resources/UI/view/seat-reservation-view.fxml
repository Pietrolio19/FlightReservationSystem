<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="contentArea"
            fx:controller="UI.controller.flight.SeatReservationController"
            fitToWidth="true">
        <content> <!-- TODO sistemare layout -->
            <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity" fillWidth="true">
                <HBox maxWidth="Infinity">
                    <VBox>
                        <HBox alignment="CENTER">
                            <VBox fx:id="airlineInfoBox" spacing="10" alignment="CENTER" styleClass="airline-box">
                                <Label fx:id="airlineLabel"/>
                                <Label fx:id="flightCodeLabel"/>
                            </VBox>

                            <HBox fx:id="departureInfoBox" spacing="5" alignment="CENTER_LEFT"
                                  styleClass="departure-box">
                                <Label fx:id="departureCityLabel"/>
                                <Label fx:id="departureIataLabel"/>
                                <Label fx:id="departureTimeLabel"/>
                                <ImageView fx:id="takeoffImage" fitWidth="18" fitHeight="18" preserveRatio="true">
                                    <image>
                                        <Image url="@../images/planeTakeoff.png"/>
                                    </image>
                                </ImageView>
                            </HBox>

                            <VBox fx:id="middleInfoBox" spacing="5" alignment="CENTER">
                                <HBox fx:id="routeLineBox" spacing="8" alignment="CENTER">
                                    <Region fx:id="leftDashedLine" prefWidth="300" maxWidth="500"
                                            styleClass="dashed-line"/>
                                    <Label fx:id="durationLabel"/>
                                    <Region fx:id="rightDashedLine" prefWidth="300" maxWidth="500"
                                            styleClass="dashed-line"/>
                                </HBox>
                            </VBox>

                            <HBox fx:id="arrivalInfoBox" spacing="5" alignment="CENTER_RIGHT" styleClass="arrival-box">
                                <ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                                    <image>
                                        <Image url="@../images/planeLand.png"/>
                                    </image>
                                </ImageView>
                                <Label fx:id="arrivalCityLabel"/>
                                <Label fx:id="arrivalIataLabel"/>
                                <Label fx:id="arrivalTimeLabel"/>
                            </HBox>

                        </HBox>

                        <HBox fx:id="bottomHBox" alignment="CENTER_LEFT">
                            <HBox fx:id="dateBox" alignment="CENTER_LEFT">
                                <Label fx:id="departureDateLabel" styleClass="date-label"/>
                            </HBox>

                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="minPriceLabel" styleClass="price-label"/>
                        </HBox>

                    </VBox>
                </HBox>
            </VBox>
        </content>
</ScrollPane>
