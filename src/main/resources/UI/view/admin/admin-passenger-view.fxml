<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="UI.controller.admin.AdminPassengerController"
            prefHeight="400.0" prefWidth="600.0">
    <HBox fx:id="mainBox"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">
        <VBox fx:id="leftBox">
            <Label text="Passeggeri"/>
            <ListView fx:id="passengerListView">

            </ListView>
        </VBox>
        <VBox fx:id="rightBox">
            <Label fx:id="idLabel" styleClass="admin-label-text"/>
            <Label fx:id="nameLabel" styleClass="admin-label-text"/>
            <Label fx:id="surnameLabel" styleClass="admin-label-text"/>
            <Label fx:id="dateOfBirthLabel" styleClass="admin-label-text"/>
            <Label fx:id="addressLabel" styleClass="admin-label-text"/>
            <Label fx:id="cityLabel" styleClass="admin-label-text"/>
            <Label fx:id="provinceLabel" styleClass="admin-label-text"/>
            <Label fx:id="countryLabel" styleClass="admin-label-text"/>
            <Label fx:id="codFiscLabel" styleClass="admin-label-text"/>
            <Label fx:id="codIDLabel" styleClass="admin-label-text"/>
            <Label fx:id="phoneNumberLabel" styleClass="admin-label-text"/>
        </VBox>

    </HBox>

</AnchorPane>
